# ===================================================================
# .env.local — Yerel ortam değişkenleri (GİT'E COMMIT ETME)
# Bu dosya örnektir: gerçek değerleri .env.local içine koy, burada TUTMA.
# ===================================================================

# -------------------------------------------------------------------
# Supabase — Proje bağlantısı
# -------------------------------------------------------------------
SB_PROJECT_URL="https://YOUR_PROJECT_REF.supabase.co"

# -------------------------------------------------------------------
# Supabase — API anahtarları
# -------------------------------------------------------------------
# Anon key: public, istemci tarafında kullanılabilir (RLS uygulanır)
SB_ANON_KEY="your_supabase_anon_key"

# Service role key: RLS'i BYPASS eder, full DB erişimi — SADECE sunucu tarafı, asla istemciye sızdırma
SB_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# -------------------------------------------------------------------
# Supabase — Yönetim / CLI
# -------------------------------------------------------------------
# Personal access token: Supabase CLI ve Management API için (çok yetkili)
SB_ACCESS_TOKEN="sbp_your_personal_access_token"

# -------------------------------------------------------------------
# Admin paneli
# -------------------------------------------------------------------
ADMIN_PASSWORD="your_admin_password"

# -------------------------------------------------------------------
# Vite / React uygulaması (build-time + yerel dev)
# -------------------------------------------------------------------
# src/lib/env.ts bu VITE_ önekli isimleri okur. Production'da Coolify
# entrypoint (docker-entrypoint-env.sh) bunları runtime'da enjekte eder;
# yerel "npm run dev" için burada tanımlı olmaları gerekir.
# NOT: Değerler yukarıdaki SB_PROJECT_URL / SB_ANON_KEY ile aynıdır (public).
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

DEEPL_API_KEY="your_deepl_api_key:fx"
